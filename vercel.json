{
  "version": 2,
  "builds": [
    { "src": "api/*.py", "use": "@vercel/python" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/slate",   "dest": "/api/slate.py"   },
    { "src": "/api/metrics", "dest": "/api/metrics.py" },
    { "src": "/api/history", "dest": "/api/history.py" },
    { "src": "/api/status",  "dest": "/api/status.py"  },
    { "src": "/(.*)",        "dest": "/index.html"      }
  ],
  "env": {
    "GITHUB_USER":   "childersjac-max",
    "GITHUB_REPO":   "Line-Tracker-Model",
    "GITHUB_BRANCH": "main"
  }
}
